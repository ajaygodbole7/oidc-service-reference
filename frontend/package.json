{
  "name": "oidc-service-reference-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "26.3.0"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "postinstall": "node scripts/sign-native-bindings.mjs",
    "dev": "vite --host 127.0.0.1",
    "build": "pnpm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test tests/e2e/auth.spec.ts",
    "check:bundle": "node scripts/check-bundle-size.js",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run check:bundle"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.16",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.21.0",
    "radix-ui": "1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "9.0.0",
    "@playwright/test": "1.60.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.15.0",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "9.0.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-refresh": "0.4.0",
    "jsdom": "26.1.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.0.0",
    "vite": "8.0.16",
    "vitest": "4.1.7"
  }
}
