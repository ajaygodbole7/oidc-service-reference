# Local reference defaults. These match the checked-in Keycloak realm and are
# safe only for local development.

CSRF_SIGNING_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
AUTH_CLIENT_ID=commerce-auth
AUTH_CLIENT_SECRET=LOCAL_DEV_AUTH_CLIENT_SECRET__CHANGE_BEFORE_DEPLOY
GATEWAY_CLIENT_SECRET=LOCAL_DEV_GATEWAY_CLIENT_SECRET__CHANGE_BEFORE_DEPLOY

OIDC_ISSUER_URI=http://localhost:8080/realms/oidc-service-reference
APP_AUTHORIZATION_URI=http://localhost:8080/realms/oidc-service-reference/protocol/openid-connect/auth
APP_TOKEN_URI=http://keycloak:8080/realms/oidc-service-reference/protocol/openid-connect/token
APP_JWKS_URI=http://keycloak:8080/realms/oidc-service-reference/protocol/openid-connect/certs
APP_END_SESSION_URI=http://localhost:8080/realms/oidc-service-reference/protocol/openid-connect/logout

OIDC_SCOPES=openid,profile,email,roles,api.audience,api.read
OIDC_AUDIENCE=commerce-api
OIDC_ROLES_CLAIM_PATH=realm_access,roles
APP_REFRESH_REQUIRE_ROTATION=true

# Internal trust identifiers. Defaults match the checked-in Keycloak realm.
# Real IdPs (Okta/Auth0/Entra) assign client ids you don't choose — set these
# to whatever the target IdP issues. GATEWAY_CLIENT_ID must be set for BOTH the
# Auth Service and the APISIX render (the gateway authenticates as it, and the
# Auth Service requires it on the /internal/resolve caller).
GATEWAY_CLIENT_ID=commerce-api-gateway
INTERNAL_REFRESH_AUDIENCE=commerce-auth-internal
RS_SERVICE_CLIENT_IDS=commerce-api-gateway,order-service
RS_JOBS_CLIENT_ID=order-service
